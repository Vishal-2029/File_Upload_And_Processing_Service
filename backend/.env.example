# Server
HTTP_ADDR=:3000

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRY_HOURS=72

# PostgreSQL
POSTGRES_DSN=postgres://postgres:postgres@localhost:5432/fileservice?sslmode=disable

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=uploads
MINIO_USE_SSL=false

# SMTP (MailHog defaults)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@fileservice.dev

# File processing
TMP_DIR=/tmp/fileservice
PROCESSED_DIR=/tmp/fileservice/processed
MAX_FILE_SIZE_MB=50

# Worker pool
WORKER_COUNT=10
JOB_QUEUE_SIZE=1000

# Rate limiting (uploads per second per user)
RATE_LIMIT_RPS=1.67
RATE_LIMIT_BURST=10
